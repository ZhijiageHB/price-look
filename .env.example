# 飞书机器人地址（自选币种分钟行情）
FEISHU_PRICE_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的webhook地址

# 飞书机器人地址（持仓推送）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的webhook地址

# 飞书机器人地址（大盘指数推送）
FEISHU_INDEX_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的webhook地址

# 币安接口地址
BINANCE_BASE_URL=https://fapi.binance.com

# 币安只读 API Key/Secret（在币安 API 管理页面创建，权限选择"只读"即可）
BINANCE_API_KEY=你的APIKey
BINANCE_API_SECRET=你的APISecret

# 关注的币对列表，多个用英文逗号分隔
SYMBOLS=MRVLUSDT,MUUSDT,SNDKUSDT,ARMUSDT,NOKUSDT,FLNCUSDT

# HTTP 请求超时时间，单位秒
REQUEST_TIMEOUT=10

# 每分钟整点后延迟几秒发送，避免上一分钟 K 线未完全落库
SEND_DELAY_SECONDS=2
